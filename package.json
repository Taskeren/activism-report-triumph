{
  "name": "activism-report-triumph",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "run-p --npm-path pnpm type-check \"build-only {@}\" --",
    "preview": "vp preview",
    "build-only": "vp build",
    "type-check": "vue-tsc --build",
    "lint": "run-s \"lint:*\"",
    "lint:oxlint": "vp lint . --fix",
    "lint:eslint": "vp lint . --fix",
    "format": "vp fmt src/",
    "prepare": "vp config",
    "deploy": "wrangler deploy --minify"
  },
  "dependencies": {
    "@lucide/vue": "^1.23.0",
    "@tailwindcss/vite": "^4.3.2",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "reka-ui": "^2.10.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "vue": "^3.5.38",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@taskeren/bungie-api-ts": "^5.10.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "jiti": "^2.7.0",
    "npm-run-all2": "^9.0.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.0",
    "vite": "catalog:",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vite-plus": "catalog:",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5",
    "wrangler": "^4.107.0"
  },
  "prettier": {
    "semi": true,
    "tabWidth": 2,
    "trailingComma": "all",
    "useTabs": false
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.10.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  }
}
