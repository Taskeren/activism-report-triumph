{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "activism-report-triumph",
  "compatibility_date": "2026-07-06",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
  },
  "build": {
    "command": "pnpm run build",
    "watch_dir": "src",
  },
}
